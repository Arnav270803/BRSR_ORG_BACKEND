generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CompanyStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}

enum MembershipRole {
  ADMIN
  USER
}

enum MembershipStatus {
  ACTIVE
  DISABLED
}

enum AuthProvider {
  GOOGLE
  LINKEDIN
}

enum CompanySiteType {
  OFFICE
  PLANT
  WAREHOUSE
  BRANCH
  FACTORY
  OTHER
}

enum CompanySiteStatus {
  ACTIVE
  DISABLED
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum VendorMembershipRole {
  VENDOR_ADMIN
  VENDOR_CONTRIBUTOR
}

enum VendorTrackingMode {
  NONE
  OPTIONAL
  REQUIRED
}

enum VendorDataRequestStatus {
  DRAFT
  SENT
  IN_PROGRESS
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  OVERDUE
  CANCELLED
}

enum DataOrigin {
  INTERNAL
  VENDOR
}

model User {
  id        String  @id @default(uuid()) @db.Uuid
  googleSub String? @unique @map("google_sub")
  email     String  @unique
  name      String?
  avatarUrl String? @map("avatar_url")

  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  memberships                   CompanyMembership[]
  siteMemberships               CompanySiteMembership[]
  identities                    UserIdentity[]
  refreshTokens                 RefreshToken[]
  sentInvitations               Invitation[]                  @relation("InvitationInvitedBy")
  acceptedInvitations           Invitation[]                  @relation("InvitationAcceptedBy")
  selectedGhgActivitySelections CompanyGhgActivitySelection[] @relation("GhgSelectionSelectedBy")
  createdDataRecords            DataRecord[]                  @relation("DataRecordCreatedBy")
  deletedDataRecords            DataRecord[]                  @relation("DataRecordDeletedBy")
  createdVendors                Vendor[]                      @relation("VendorCreatedBy")
  vendorMemberships             VendorMembership[]
  sentVendorInvitations         VendorInvitation[]            @relation("VendorInvitationInvitedBy")
  acceptedVendorInvitations     VendorInvitation[]            @relation("VendorInvitationAcceptedBy")
  createdVendorSiteAssignments  VendorSiteAssignment[]        @relation("VendorSiteAssignmentCreatedBy")
  createdVendorDataRequests     VendorDataRequest[]           @relation("VendorDataRequestCreatedBy")
  reviewedVendorDataRequests    VendorDataRequest[]           @relation("VendorDataRequestReviewedBy")
  vendorSubmissionRecords       VendorSubmissionRecord[]      @relation("VendorSubmissionCreatedBy")
  auditLogs                     AuditLog[]                    @relation("AuditActor")

  @@map("users")
}

model UserIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  email          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([email])
  @@map("user_identities")
}

model Company {
  id                      String @id @default(uuid()) @db.Uuid
  legalName               String @map("legal_name")
  displayName             String @map("display_name")
  primaryDomain           String @map("primary_domain")
  industry                String
  country                 String
  state                   String
  city                    String
  financialYearStartMonth Int    @map("financial_year_start_month")

  cin                   String?
  gst                   String?
  registeredAddress     String? @map("registered_address")
  listedStatus          String? @map("listed_status")
  employeeCountRange    String? @map("employee_count_range")
  contactPhone          String? @map("contact_phone")
  logoUrl               String? @map("logo_url")
  vendorTrackingEnabled Boolean @default(false) @map("vendor_tracking_enabled")

  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  memberships             CompanyMembership[]
  sites                   CompanySite[]
  siteMemberships         CompanySiteMembership[]
  invitations             Invitation[]
  reportingYears          ReportingYear[]
  ghgActivitySelections   CompanyGhgActivitySelection[]
  dataRecords             DataRecord[]
  vendors                 Vendor[]
  vendorSiteAssignments   VendorSiteAssignment[]
  vendorMemberships       VendorMembership[]
  vendorInvitations       VendorInvitation[]
  vendorDataRequests      VendorDataRequest[]
  vendorSubmissionRecords VendorSubmissionRecord[]
  auditLogs               AuditLog[]

  @@index([primaryDomain])
  @@map("companies")
}

model GhgCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  sourceSheet String  @unique @map("source_sheet")
  scope       String?
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities GhgActivity[]

  @@index([scope])
  @@index([isActive])
  @@map("ghg_categories")
}

model GhgActivity {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  sourceSheet   String  @map("source_sheet")
  sourceYear    Int?    @map("source_year")
  sourceVersion String? @map("source_version")
  sourceRow     Int     @map("source_row")

  scope    String?
  activity String
  subtype  String  @default("")
  variant  String  @default("")
  unit     String

  factorKgCo2e Decimal? @map("factor_kg_co2e") @db.Decimal(24, 10)
  factorData   Json?    @map("factor_data")
  rawData      Json?    @map("raw_data")

  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  category          GhgCategory                   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  companySelections CompanyGhgActivitySelection[]
  dataRecords       DataRecord[]

  @@unique([sourceSheet, sourceRow, unit, activity, subtype, variant])
  @@index([categoryId])
  @@index([scope])
  @@index([activity])
  @@index([unit])
  @@index([isActive])
  @@map("ghg_activities")
}

model ReportingYear {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  label     String
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company                 Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ghgActivitySelections   CompanyGhgActivitySelection[]
  dataRecords             DataRecord[]
  vendorDataRequests      VendorDataRequest[]
  vendorSubmissionRecords VendorSubmissionRecord[]

  @@unique([companyId, label])
  @@unique([companyId, startDate, endDate])
  @@index([companyId])
  @@index([isActive])
  @@map("reporting_years")
}

model CompanySite {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  name      String
  type      CompanySiteType   @default(OTHER)
  country   String
  state     String
  city      String
  address   String?           @db.Text
  isPrimary Boolean           @default(false) @map("is_primary")
  status    CompanySiteStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company                 Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships             CompanySiteMembership[]
  ghgActivitySelections   CompanyGhgActivitySelection[]
  dataRecords             DataRecord[]
  vendorAssignments       VendorSiteAssignment[]
  vendorDataRequests      VendorDataRequest[]
  vendorSubmissionRecords VendorSubmissionRecord[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([companyId, isPrimary])
  @@index([status])
  @@map("company_sites")
}

model CompanySiteMembership {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  siteId    String @map("site_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  role   MembershipRole   @default(USER)
  status MembershipStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site    CompanySite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([companyId, userId])
  @@index([siteId])
  @@index([userId])
  @@index([status])
  @@map("company_site_memberships")
}

model CompanyGhgActivitySelection {
  id              String @id @default(uuid()) @db.Uuid
  companyId       String @map("company_id") @db.Uuid
  siteId          String @map("site_id") @db.Uuid
  reportingYearId String @map("reporting_year_id") @db.Uuid
  ghgActivityId   String @map("ghg_activity_id") @db.Uuid

  customLabel        String?            @map("custom_label")
  isEnabled          Boolean            @default(true) @map("is_enabled")
  vendorTrackingMode VendorTrackingMode @default(NONE) @map("vendor_tracking_mode")
  selectedAt         DateTime           @default(now()) @map("selected_at")
  disabledAt         DateTime?          @map("disabled_at")

  selectedByUserId String? @map("selected_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site                    CompanySite              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reportingYear           ReportingYear            @relation(fields: [reportingYearId], references: [id], onDelete: Cascade)
  ghgActivity             GhgActivity              @relation(fields: [ghgActivityId], references: [id], onDelete: Restrict)
  selectedBy              User?                    @relation("GhgSelectionSelectedBy", fields: [selectedByUserId], references: [id], onDelete: SetNull)
  dataRecords             DataRecord[]
  vendorDataRequestItems  VendorDataRequestItem[]
  vendorSubmissionRecords VendorSubmissionRecord[]

  @@unique([reportingYearId, siteId, ghgActivityId])
  @@index([companyId, reportingYearId])
  @@index([companyId, siteId, reportingYearId])
  @@index([siteId])
  @@index([ghgActivityId])
  @@index([isEnabled])
  @@map("company_ghg_activity_selections")
}

model DataRecord {
  id                     String @id @default(uuid()) @db.Uuid
  companyId              String @map("company_id") @db.Uuid
  siteId                 String @map("site_id") @db.Uuid
  reportingYearId        String @map("reporting_year_id") @db.Uuid
  ghgActivitySelectionId String @map("ghg_activity_selection_id") @db.Uuid
  ghgActivityId          String @map("ghg_activity_id") @db.Uuid

  recordDate          DateTime @map("record_date") @db.Date
  quantity            Decimal  @db.Decimal(24, 10)
  unit                String
  factorKgCo2e        Decimal? @map("factor_kg_co2e") @db.Decimal(24, 10)
  calculatedKgCo2e    Decimal? @map("calculated_kg_co2e") @db.Decimal(24, 10)
  scope               String?
  factorSourceSheet   String?  @map("factor_source_sheet")
  factorSourceYear    Int?     @map("factor_source_year")
  factorSourceVersion String?  @map("factor_source_version")

  notes                    String?    @db.Text
  metadata                 Json?
  dataOrigin               DataOrigin @default(INTERNAL) @map("data_origin")
  vendorId                 String?    @map("vendor_id") @db.Uuid
  vendorSubmissionRecordId String?    @unique @map("vendor_submission_record_id") @db.Uuid

  createdByUserId String    @map("created_by_user_id") @db.Uuid
  deletedByUserId String?   @map("deleted_by_user_id") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company                Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site                   CompanySite                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  reportingYear          ReportingYear               @relation(fields: [reportingYearId], references: [id], onDelete: Cascade)
  ghgActivitySelection   CompanyGhgActivitySelection @relation(fields: [ghgActivitySelectionId], references: [id], onDelete: Restrict)
  ghgActivity            GhgActivity                 @relation(fields: [ghgActivityId], references: [id], onDelete: Restrict)
  createdBy              User                        @relation("DataRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  deletedBy              User?                       @relation("DataRecordDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  vendor                 Vendor?                     @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  vendorSubmissionRecord VendorSubmissionRecord?     @relation("ApprovedVendorDataRecord", fields: [vendorSubmissionRecordId], references: [id], onDelete: SetNull)

  @@index([companyId, reportingYearId])
  @@index([companyId, siteId, reportingYearId])
  @@index([companyId, siteId, reportingYearId, deletedAt], map: "data_records_company_site_year_deleted_idx")
  @@index([siteId])
  @@index([ghgActivitySelectionId])
  @@index([ghgActivityId])
  @@index([createdByUserId])
  @@index([vendorId])
  @@index([dataOrigin])
  @@index([deletedAt])
  @@index([recordDate])
  @@map("data_records")
}

model CompanyMembership {
  id        String           @id @default(uuid()) @db.Uuid
  companyId String           @map("company_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_memberships")
}

model Invitation {
  id        String         @id @default(uuid()) @db.Uuid
  companyId String         @map("company_id") @db.Uuid
  email     String
  role      MembershipRole
  tokenHash String         @unique @map("token_hash")

  invitedByUserId  String  @map("invited_by_user_id") @db.Uuid
  acceptedByUserId String? @map("accepted_by_user_id") @db.Uuid

  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy  User    @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy User?   @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, email])
  @@index([expiresAt])
  @@map("invitations")
}

model Vendor {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid

  legalName    String  @map("legal_name")
  displayName  String  @map("display_name")
  vendorCode   String? @map("vendor_code")
  primaryEmail String  @map("primary_email")
  primaryPhone String? @map("primary_phone")
  website      String?
  industry     String?
  country      String
  state        String
  city         String
  address      String? @db.Text
  taxId        String? @map("tax_id")

  status             VendorStatus @default(PENDING)
  profileCompletedAt DateTime?    @map("profile_completed_at")
  createdByUserId    String       @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy         User                     @relation("VendorCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  siteAssignments   VendorSiteAssignment[]
  memberships       VendorMembership[]
  invitations       VendorInvitation[]
  dataRequests      VendorDataRequest[]
  submissionRecords VendorSubmissionRecord[]
  dataRecords       DataRecord[]

  @@unique([companyId, primaryEmail])
  @@unique([companyId, vendorCode])
  @@index([companyId, status])
  @@index([displayName])
  @@map("vendors")
}

model VendorSiteAssignment {
  id              String @id @default(uuid()) @db.Uuid
  companyId       String @map("company_id") @db.Uuid
  vendorId        String @map("vendor_id") @db.Uuid
  siteId          String @map("site_id") @db.Uuid
  createdByUserId String @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor    Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  site      CompanySite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy User        @relation("VendorSiteAssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([vendorId, siteId])
  @@index([companyId, siteId])
  @@index([vendorId])
  @@map("vendor_site_assignments")
}

model VendorMembership {
  id        String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  vendorId  String @map("vendor_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  role   VendorMembershipRole @default(VENDOR_CONTRIBUTOR)
  status MembershipStatus     @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
  @@index([companyId, userId])
  @@index([userId, status])
  @@map("vendor_memberships")
}

model VendorInvitation {
  id        String               @id @default(uuid()) @db.Uuid
  companyId String               @map("company_id") @db.Uuid
  vendorId  String               @map("vendor_id") @db.Uuid
  email     String
  role      VendorMembershipRole @default(VENDOR_ADMIN)
  tokenHash String               @unique @map("token_hash")

  invitedByUserId  String  @map("invited_by_user_id") @db.Uuid
  acceptedByUserId String? @map("accepted_by_user_id") @db.Uuid

  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor     Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invitedBy  User    @relation("VendorInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy User?   @relation("VendorInvitationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, vendorId])
  @@index([email, expiresAt])
  @@map("vendor_invitations")
}

model VendorDataRequest {
  id              String @id @default(uuid()) @db.Uuid
  companyId       String @map("company_id") @db.Uuid
  vendorId        String @map("vendor_id") @db.Uuid
  siteId          String @map("site_id") @db.Uuid
  reportingYearId String @map("reporting_year_id") @db.Uuid

  title        String
  instructions String?                 @db.Text
  dueDate      DateTime                @map("due_date") @db.Date
  status       VendorDataRequestStatus @default(DRAFT)
  reviewNotes  String?                 @map("review_notes") @db.Text

  createdByUserId  String  @map("created_by_user_id") @db.Uuid
  reviewedByUserId String? @map("reviewed_by_user_id") @db.Uuid

  sentAt             DateTime? @map("sent_at")
  submittedAt        DateTime? @map("submitted_at")
  approvedAt         DateTime? @map("approved_at")
  changesRequestedAt DateTime? @map("changes_requested_at")
  cancelledAt        DateTime? @map("cancelled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company           Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor            Vendor                   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  site              CompanySite              @relation(fields: [siteId], references: [id], onDelete: Restrict)
  reportingYear     ReportingYear            @relation(fields: [reportingYearId], references: [id], onDelete: Restrict)
  createdBy         User                     @relation("VendorDataRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  reviewedBy        User?                    @relation("VendorDataRequestReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  items             VendorDataRequestItem[]
  submissionRecords VendorSubmissionRecord[]

  @@index([companyId, reportingYearId, siteId])
  @@index([vendorId, status])
  @@index([dueDate, status])
  @@map("vendor_data_requests")
}

model VendorDataRequestItem {
  id                     String             @id @default(uuid()) @db.Uuid
  vendorDataRequestId    String             @map("vendor_data_request_id") @db.Uuid
  ghgActivitySelectionId String             @map("ghg_activity_selection_id") @db.Uuid
  trackingMode           VendorTrackingMode @map("tracking_mode")
  instructions           String?            @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  dataRequest          VendorDataRequest           @relation(fields: [vendorDataRequestId], references: [id], onDelete: Cascade)
  ghgActivitySelection CompanyGhgActivitySelection @relation(fields: [ghgActivitySelectionId], references: [id], onDelete: Restrict)
  submissionRecords    VendorSubmissionRecord[]

  @@unique([vendorDataRequestId, ghgActivitySelectionId])
  @@index([ghgActivitySelectionId])
  @@map("vendor_data_request_items")
}

model VendorSubmissionRecord {
  id                      String @id @default(uuid()) @db.Uuid
  companyId               String @map("company_id") @db.Uuid
  vendorId                String @map("vendor_id") @db.Uuid
  siteId                  String @map("site_id") @db.Uuid
  reportingYearId         String @map("reporting_year_id") @db.Uuid
  vendorDataRequestId     String @map("vendor_data_request_id") @db.Uuid
  vendorDataRequestItemId String @map("vendor_data_request_item_id") @db.Uuid
  ghgActivitySelectionId  String @map("ghg_activity_selection_id") @db.Uuid

  recordDate DateTime @map("record_date") @db.Date
  quantity   Decimal  @db.Decimal(24, 10)
  notes      String?  @db.Text
  metadata   Json?

  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company              Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor               Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  site                 CompanySite                 @relation(fields: [siteId], references: [id], onDelete: Restrict)
  reportingYear        ReportingYear               @relation(fields: [reportingYearId], references: [id], onDelete: Restrict)
  dataRequest          VendorDataRequest           @relation(fields: [vendorDataRequestId], references: [id], onDelete: Cascade)
  requestItem          VendorDataRequestItem       @relation(fields: [vendorDataRequestItemId], references: [id], onDelete: Cascade)
  ghgActivitySelection CompanyGhgActivitySelection @relation(fields: [ghgActivitySelectionId], references: [id], onDelete: Restrict)
  createdBy            User                        @relation("VendorSubmissionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedDataRecord   DataRecord?                 @relation("ApprovedVendorDataRecord")

  @@index([vendorDataRequestId])
  @@index([vendorDataRequestItemId])
  @@index([companyId, reportingYearId, siteId])
  @@index([vendorId])
  @@map("vendor_submission_records")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  createdByIp String? @map("created_by_ip")
  userAgent   String? @map("user_agent") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String  @id @default(uuid()) @db.Uuid
  companyId   String? @map("company_id") @db.Uuid
  actorUserId String? @map("actor_user_id") @db.Uuid

  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id")

  beforeJson Json? @map("before_json")
  afterJson  Json? @map("after_json")

  createdAt DateTime @default(now()) @map("created_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actor   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([actorUserId])
  @@index([action])
  @@map("audit_logs")
}
